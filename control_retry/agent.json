{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.control_retry.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "fallback_message_type": "retry_scheduled",
          "message_type": "with.output_message_type"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "retry_policy"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "retry_decision_emitted",
            "type": "terminate"
          },
          "when": {
            "type": "always"
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Emit a retry-control decision using declared policy and attempt metadata."
  },
  "defaults": {
    "agent_type": "router",
    "type": "map"
  },
  "description": "Routes retry decisions with bounded attempts and backoff metadata.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "node_type",
      "role",
      "max_attempts",
      "backoff_ms",
      "jitter",
      "output_message_type"
    ],
    "required": [
      "retry_policy"
    ]
  },
  "kind": "router",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "retry_control",
    "bounded_retries"
  ],
  "renders_to": "manifest.nodes[]",
  "template_category": "control",
  "template_id": "mn-agents.control_retry",
  "version": 1
}
