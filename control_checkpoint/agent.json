{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.control_checkpoint.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "fallback_message_type": "checkpoint_recorded",
          "message_type": "with.output_message_type"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "checkpoint_key",
      "runner_module"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "checkpoint_recorded",
            "type": "terminate"
          },
          "when": {
            "type": "always"
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Record a deterministic checkpoint marker for later resume or audit."
  },
  "defaults": {
    "agent_type": "executor",
    "runner_module": "MirrorNeuron.Runner.HostLocal",
    "type": "map"
  },
  "description": "Records checkpoint and resume metadata for stateful workflows.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "node_type",
      "role",
      "checkpoint_mode",
      "output_message_type"
    ],
    "required": [
      "checkpoint_key"
    ]
  },
  "kind": "executor",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "state_checkpoint",
    "resume_metadata"
  ],
  "renders_to": "manifest.nodes[]",
  "template_category": "control",
  "template_id": "mn-agents.control_checkpoint",
  "version": 1
}
