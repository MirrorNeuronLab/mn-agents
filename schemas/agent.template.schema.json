{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": 1,
  "properties": {
    "inputs": {
      "type": "object"
    },
    "behavior": {
      "type": "object",
      "required": [
        "schema_version",
        "summary",
        "lifecycle_events",
        "required_config",
        "emits"
      ],
      "properties": {
        "schema_version": {
          "const": "mn.agent.behavior.v1"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "lifecycle_events": {
          "type": "object",
          "required": [
            "success",
            "failure"
          ],
          "properties": {
            "success": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            },
            "failure": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1
            }
          }
        },
        "required_config": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "emits": {
          "type": "object",
          "required": [
            "events",
            "messages",
            "artifacts"
          ],
          "properties": {
            "events": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "messages": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "message_type"
                ],
                "properties": {
                  "message_type": {
                    "type": "string"
                  },
                  "fallback_message_type": {
                    "type": "string"
                  }
                }
              }
            },
            "artifacts": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "artifact_id"
                ],
                "properties": {
                  "artifact_id": {
                    "type": "string"
                  },
                  "mime_type": {
                    "type": "string"
                  },
                  "schema": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "routing": {
          "type": "object",
          "properties": {
            "transitions": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "when",
                  "then"
                ],
                "properties": {
                  "when": {
                    "type": "object",
                    "required": [
                      "type"
                    ],
                    "properties": {
                      "type": {
                        "enum": [
                          "always",
                          "from_message_type",
                          "tool_called",
                          "context_equals"
                        ]
                      }
                    }
                  },
                  "then": {
                    "type": "object",
                    "required": [
                      "type"
                    ],
                    "properties": {
                      "type": {
                        "enum": [
                          "terminate"
                        ]
                      },
                      "reason": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "delegation": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "inherits_tools": {
              "type": "boolean"
            },
            "allow_recursive": {
              "const": false
            }
          }
        }
      }
    },
    "kind": {
      "type": "string"
    },
    "template_category": {
      "enum": [
        "control",
        "data"
      ]
    },
    "template_id": {
      "type": "string"
    },
    "version": {
      "const": 1
    }
  },
  "required": [
    "template_id",
    "template_category",
    "version",
    "kind",
    "description",
    "inputs",
    "input_spec",
    "output_spec",
    "payloads",
    "defaults",
    "provides",
    "renders_to",
    "behavior"
  ],
  "title": "MirrorNeuron Agent Template",
  "type": "object"
}
