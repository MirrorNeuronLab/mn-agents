{
  "defaults": {
    "agent_type": "executor",
    "runner_module": "MirrorNeuron.Runner.HostLocal",
    "type": "map"
  },
  "description": "Named LLM_CONFIG based LLM agent with optional A2A discovery metadata.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "node_type",
      "system_prompt_ref",
      "tools",
      "output_message_type"
    ],
    "required": [
      "llm_config",
      "role"
    ]
  },
  "kind": "executor",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "protocol_adapters": {
    "a2a": {
      "agent_card": "a2a/agent-card.json",
      "enabled": true,
      "input_envelope": "Message",
      "output_envelope": "Artifact",
      "recommended_for": [
        "python_llm_agent"
      ]
    }
  },
  "provides": [
    "llm_call",
    "a2a_optional",
    "structured_decision"
  ],
  "renders_to": "manifest.nodes[]",
  "template_id": "mn-agents.llm_agent",
  "version": "1.0.0"
}
