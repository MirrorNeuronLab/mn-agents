{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.module.beam_module.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "fallback_message_type": "module_completed",
          "message_type": "config.emit_type"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "module",
      "module_source",
      "emit_type"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "agent_completed",
            "type": "terminate"
          },
          "when": {
            "type": "always"
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Load a BEAM module node that emits typed workflow messages."
  },
  "defaults": {
    "agent_type": "module",
    "type": "generic"
  },
  "description": "Generic BEAM module node with module source and emitted message type.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "stereotype",
      "node_type",
      "role",
      "backpressure",
      "answer_node"
    ],
    "required": [
      "module",
      "module_source",
      "emit_type"
    ]
  },
  "kind": "module",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "runtime_shape",
    "rendered_manifest_node",
    "behavior_simulation"
  ],
  "renders_to": "manifest.nodes[]",
  "stereotypes": {},
  "template_category": "data",
  "template_id": "mn-agents.module.beam_module",
  "version": 1
}
