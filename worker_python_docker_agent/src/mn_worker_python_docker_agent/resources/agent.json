{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.worker.python_docker.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "fallback_message_type": "worker_completed",
          "message_type": "config.output_message_type"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "command",
      "runner_module",
      "upload_path",
      "workdir",
      "docker_worker_image",
      "image"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "agent_completed",
            "type": "terminate"
          },
          "when": {
            "type": "always"
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Run a Python script in a DockerWorker container with concrete image, upload, and liveness config."
  },
  "defaults": {
    "agent_beacon_required": true,
    "agent_type": "executor",
    "beacon_enabled": true,
    "beacon_interval_ms": 15000,
    "beacon_missed_action": "fail_attempt",
    "beacon_timeout_ms": 45000,
    "cleanup_remote_dir": true,
    "from": "base",
    "idempotent": true,
    "no_auto_providers": true,
    "no_keep": true,
    "pool": "default",
    "pool_slots": 1,
    "reuse_shared_container": true,
    "runner_module": "MirrorNeuron.Runner.DockerWorker",
    "safe_to_retry": true,
    "shared_container": true,
    "tty": false,
    "type": "generic",
    "workdir_template": "/mn/job/{upload_path}"
  },
  "description": "Generic Python worker executed by MirrorNeuron.Runner.DockerWorker.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "stereotype",
      "node_type",
      "role",
      "output_message_type",
      "environment",
      "upload_paths",
      "network",
      "pool",
      "pool_slots",
      "workdir",
      "command",
      "side_effect",
      "timeout_seconds",
      "max_attempts",
      "retry_backoff_ms"
    ],
    "required": [
      "upload_path",
      "docker_worker_image",
      "image"
    ],
    "required_unless_command": [
      "script"
    ]
  },
  "kind": "executor",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "runtime_shape",
    "rendered_manifest_node",
    "behavior_simulation"
  ],
  "renders_to": "manifest.nodes[]",
  "stereotypes": {
    "blueprint_docker_worker": {
      "description": "Shared-container Docker worker for standard blueprint bundles.",
      "with": {
        "command": [
          "python3",
          "-m",
          "mn_sdk.step_runtime"
        ],
        "docker_worker_image": "docker_worker",
        "network": "mirror-neuron-runtime",
        "side_effect": "read",
        "upload_as": "runtime",
        "upload_path": "runtime",
        "workdir": "/mn/job/runtime"
      }
    },
    "internal_write_worker": {
      "description": "Docker worker that writes internal run artifacts.",
      "with": {
        "side_effect": "internal_write"
      }
    },
    "public_browser_worker": {
      "description": "Docker worker allowed to read public network/browser sources.",
      "with": {
        "environment": {
          "W3M_BROWSER_MAX_CHARS": "6000",
          "W3M_BROWSER_TIMEOUT_SECONDS": "12",
          "WEB_BROWSER_MAX_CHARS": "12000",
          "WEB_BROWSER_RESPECT_ROBOTS": "true",
          "WEB_BROWSER_TIMEOUT_SECONDS": "20"
        },
        "side_effect": "network_read"
      }
    }
  },
  "template_category": "data",
  "template_id": "mn-agents.worker.python_docker",
  "version": 1,
  "schema_version": "mn.agent.package.v1",
  "package_kind": "runtime_node",
  "agent_id": "mn-agents.worker.python_docker",
  "python": {
    "distribution": "mn-worker-python-docker-agent",
    "module": "mn_worker_python_docker_agent",
    "factory": "create_agent",
    "definition_loader": "load_agent_definition"
  }
}
