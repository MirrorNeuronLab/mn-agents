{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.control_input_listener.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "message_type": "input_skill_event"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "module",
      "skill_name"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "input_skill_event_emitted",
            "type": "terminate"
          },
          "when": {
            "type": "always"
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Listen for connector-backed input skill events and emit normalized input records."
  },
  "defaults": {
    "agent_type": "module",
    "module": "MirrorNeuron.Agents.InputSkillListener",
    "type": "stream"
  },
  "description": "Listens to connector-backed input skills such as Drive, Slack, webhook, socket, or WebSocket inputs.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "node_type",
      "role",
      "event_types",
      "live",
      "backpressure"
    ],
    "required": [
      "skill_name"
    ]
  },
  "kind": "listener",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "input_skill_events",
    "stream_subscription"
  ],
  "renders_to": "manifest.nodes[]",
  "template_category": "control",
  "template_id": "mn-agents.control_input_listener",
  "version": 1
}
