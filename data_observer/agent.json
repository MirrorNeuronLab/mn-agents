{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.data_observer.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "fallback_message_type": "observation_event",
          "message_type": "with.output_message_type"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "observation_source",
      "runner_module"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "observation_emitted",
            "type": "terminate"
          },
          "when": {
            "type": "always"
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Read an observation source and emit a normalized observation event."
  },
  "defaults": {
    "agent_type": "executor",
    "runner_module": "MirrorNeuron.Runner.HostLocal",
    "type": "map"
  },
  "description": "Observes a stream, file, sensor, or service and emits normalized observations.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "node_type",
      "role",
      "observation_mode",
      "output_message_type"
    ],
    "required": [
      "observation_source"
    ]
  },
  "kind": "executor",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "observation",
    "sensor_reading",
    "normalized_events"
  ],
  "renders_to": "manifest.nodes[]",
  "template_category": "data",
  "template_id": "mn-agents.data_observer",
  "version": 1
}
