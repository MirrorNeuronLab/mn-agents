{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.worker.llm_host.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "fallback_message_type": "llm_worker_completed",
          "message_type": "config.output_message_type"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "runner_module",
      "llm_config"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "agent_completed",
            "type": "terminate"
          },
          "when": {
            "type": "always"
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Run a host-local LLM worker using a named llm_config."
  },
  "defaults": {
    "agent_type": "executor",
    "beacon_enabled": true,
    "beacon_interval_ms": 15000,
    "beacon_missed_action": "fail_attempt",
    "beacon_timeout_ms": 45000,
    "runner_module": "MirrorNeuron.Runner.HostLocal",
    "type": "map"
  },
  "description": "Host-local LLM worker shape with an llm_config reference.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "stereotype",
      "node_type",
      "role",
      "output_message_type",
      "timeout_seconds",
      "max_attempts",
      "retry_backoff_ms",
      "tools",
      "system_prompt_ref"
    ],
    "required": [
      "llm_config"
    ]
  },
  "kind": "executor",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "runtime_shape",
    "rendered_manifest_node",
    "behavior_simulation"
  ],
  "renders_to": "manifest.nodes[]",
  "stereotypes": {},
  "template_category": "data",
  "template_id": "mn-agents.worker.llm_host",
  "version": 1
}
