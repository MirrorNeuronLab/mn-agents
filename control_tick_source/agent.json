{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.control_tick_source.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "fallback_message_type": "stream_tick",
          "message_type": "config.emit_type"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "emit_type",
      "interval_ms",
      "module"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "stream_tick_emitted",
            "type": "terminate"
          },
          "when": {
            "type": "always"
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Emit deterministic stream tick messages according to configured interval and stream name."
  },
  "defaults": {
    "agent_type": "module",
    "module": "MirrorNeuron.Agents.StreamTickSource",
    "type": "stream"
  },
  "description": "Reusable stream or polling tick source for live and replayed stream workflows.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "node_type",
      "role",
      "interval_ms",
      "backpressure",
      "stream_name"
    ],
    "required": [
      "emit_type"
    ]
  },
  "kind": "listener",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "stream_ticks",
    "backpressure"
  ],
  "renders_to": "manifest.nodes[]",
  "template_category": "control",
  "template_id": "mn-agents.control_tick_source",
  "version": "1.0.0"
}
