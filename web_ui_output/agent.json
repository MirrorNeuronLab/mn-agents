{
  "defaults": {
    "agent_type": "executor",
    "fallback_port": 8081,
    "primary_port": 8080,
    "runner_module": "MirrorNeuron.Runner.OpenShell",
    "type": "generic"
  },
  "description": "TCP output and web UI service using primary port 8080 and fallback port 8081.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "node_type",
      "role",
      "primary_port",
      "fallback_port",
      "custom_url"
    ],
    "required": [
      "adapter"
    ]
  },
  "kind": "service",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "web_ui",
    "tcp_output",
    "port_tunnel_verification"
  ],
  "renders_to": "manifest.nodes[]",
  "template_id": "mn-agents.web_ui_output",
  "version": "1.0.0"
}
