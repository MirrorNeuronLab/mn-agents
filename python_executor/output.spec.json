{
  "artifacts": [
    {
      "artifact_id": "result",
      "mime_type": "application/json",
      "schema": "mn-agents.python_executor.output.v1"
    }
  ],
  "description": "Outputs emitted by mn-agents.python_executor.",
  "emitted_message_types": [
    "blueprint_report"
  ],
  "events": [
    "agent_started",
    "agent_completed",
    "agent_failed"
  ],
  "examples": [
    {
      "agent_type": "executor",
      "config": {
        "command": [
          "python3",
          "scripts/run_blueprint.py"
        ],
        "from": "base",
        "no_auto_providers": true,
        "no_keep": true,
        "output_message_type": "blueprint_report",
        "pool": "default",
        "pool_slots": 1,
        "runner_module": "MirrorNeuron.Runner.HostLocal",
        "tty": false,
        "upload_as": "simulation_loop",
        "upload_path": "simulation_loop",
        "workdir": "/sandbox/job/simulation_loop"
      },
      "node_id": "simulation_loop",
      "role": "root_coordinator",
      "type": "generic"
    }
  ],
  "parts": [
    {
      "kind": "data",
      "schema": "mn-agents.python_executor.output.v1"
    }
  ],
  "schema_version": "mn.agent.output.v1"
}
