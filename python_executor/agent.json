{
  "defaults": {
    "agent_type": "executor",
    "from": "base",
    "no_auto_providers": true,
    "no_keep": true,
    "pool": "default",
    "pool_slots": 1,
    "runner_module": "MirrorNeuron.Runner.HostLocal",
    "tty": false,
    "type": "generic",
    "workdir_template": "/sandbox/job/{upload_path}"
  },
  "description": "Runs a Python script with standard blueprint lifecycle wiring.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "node_type",
      "role",
      "output_message_type",
      "environment",
      "pass_env",
      "pool",
      "pool_slots",
      "runner_module",
      "workdir",
      "name_prefix",
      "tty",
      "backpressure",
      "custom_openshell_image"
    ],
    "required": [
      "script",
      "upload_path"
    ]
  },
  "kind": "executor",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "run_store_events",
    "structured_logging",
    "error_handling",
    "artifact_writing"
  ],
  "renders_to": "manifest.nodes[]",
  "template_id": "mn-agents.python_executor",
  "version": "1.0.0"
}
