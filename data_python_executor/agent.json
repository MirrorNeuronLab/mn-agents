{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.data_python_executor.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "fallback_message_type": "blueprint_report",
          "message_type": "with.output_message_type"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "command",
      "runner_module",
      "upload_path",
      "workdir"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "python_script_completed",
            "type": "terminate"
          },
          "when": {
            "type": "always"
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Run a Python script with standard lifecycle, run-store, and artifact conventions."
  },
  "defaults": {
    "agent_type": "executor",
    "from": "base",
    "no_auto_providers": true,
    "no_keep": true,
    "pool": "default",
    "pool_slots": 1,
    "runner_module": "MirrorNeuron.Runner.HostLocal",
    "tty": false,
    "type": "generic",
    "workdir_template": "/sandbox/job/{upload_path}"
  },
  "description": "Runs a Python script with standard blueprint lifecycle wiring.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "node_type",
      "role",
      "output_message_type",
      "environment",
      "pass_env",
      "pool",
      "pool_slots",
      "runner_module",
      "workdir",
      "name_prefix",
      "tty",
      "backpressure",
      "custom_openshell_image"
    ],
    "required": [
      "script",
      "upload_path"
    ]
  },
  "kind": "executor",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "run_store_events",
    "structured_logging",
    "error_handling",
    "artifact_writing"
  ],
  "renders_to": "manifest.nodes[]",
  "template_category": "data",
  "template_id": "mn-agents.data_python_executor",
  "version": "1.0.0"
}
