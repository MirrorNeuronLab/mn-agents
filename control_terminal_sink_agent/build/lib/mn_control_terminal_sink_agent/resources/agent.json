{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.control.terminal_sink.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "message_type": "run_completed"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "complete_on_message"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "terminal_report_received",
            "type": "terminate"
          },
          "when": {
            "message_type": "blueprint_report",
            "type": "from_message_type"
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Collect the terminal workflow result and complete the run."
  },
  "defaults": {
    "agent_type": "aggregator",
    "role": "result_sink",
    "type": "reduce"
  },
  "description": "Reduce sink that marks a run complete when the final message arrives.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "stereotype",
      "node_type",
      "role",
      "complete_on_message",
      "complete_run",
      "terminal_sink",
      "output_message_type"
    ],
    "required": []
  },
  "kind": "aggregator",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "runtime_shape",
    "rendered_manifest_node",
    "behavior_simulation"
  ],
  "renders_to": "manifest.nodes[]",
  "stereotypes": {
    "terminal_report_sink": {
      "description": "Common terminal report sink used by report-producing workflows.",
      "with": {
        "complete_on_message": true,
        "complete_run": true,
        "terminal_sink": true
      }
    }
  },
  "template_category": "control",
  "template_id": "mn-agents.control.terminal_sink",
  "version": 1,
  "schema_version": "mn.agent.package.v1",
  "package_kind": "runtime_node",
  "agent_id": "mn-agents.control.terminal_sink",
  "python": {
    "distribution": "mn-control-terminal-sink-agent",
    "module": "mn_control_terminal_sink_agent",
    "factory": "create_agent",
    "definition_loader": "load_agent_definition"
  }
}
