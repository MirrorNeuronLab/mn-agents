{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.control_message_filter.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "fallback_message_type": "filtered_message",
          "message_type": "with.output_message_type"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "predicate"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "message_filter_evaluated",
            "type": "terminate"
          },
          "when": {
            "field": "predicate_result",
            "type": "context_equals",
            "value": true
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Emit a filtered handoff decision using a named predicate."
  },
  "defaults": {
    "agent_type": "router",
    "type": "map"
  },
  "description": "Filters or gates messages using a declarative predicate name.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "node_type",
      "role",
      "drop_message_type",
      "output_message_type"
    ],
    "required": [
      "predicate"
    ]
  },
  "kind": "router",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "message_filtering",
    "conditional_handoff"
  ],
  "renders_to": "manifest.nodes[]",
  "template_category": "control",
  "template_id": "mn-agents.control_message_filter",
  "version": "1.0.0"
}
