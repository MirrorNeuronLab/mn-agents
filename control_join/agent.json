{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.control_join.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "message_type": "run_completed"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "complete_on_message"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "report_collected",
            "type": "terminate"
          },
          "when": {
            "message_type": "blueprint_report",
            "type": "from_message_type"
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Collect final report messages and complete the run when the report is received."
  },
  "defaults": {
    "agent_type": "aggregator",
    "complete_on_message": true,
    "role": "result_sink",
    "type": "reduce"
  },
  "description": "Reduce/aggregator sink that completes when a configured message arrives.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "node_type",
      "role",
      "complete_on_message",
      "complete_run",
      "terminal_sink",
      "output_message_type"
    ],
    "required": []
  },
  "kind": "aggregator",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "completion_detection",
    "result_collection"
  ],
  "renders_to": "manifest.nodes[]",
  "template_category": "control",
  "template_id": "mn-agents.control_join",
  "version": 1
}
