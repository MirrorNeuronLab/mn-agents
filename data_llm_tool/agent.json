{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.data_llm_tool.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "fallback_message_type": "llm_tool_result",
          "message_type": "with.output_message_type"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "llm_config",
      "tools",
      "runner_module"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "llm_tool_result_emitted",
            "type": "terminate"
          },
          "when": {
            "tool_name": "search_docs",
            "type": "tool_called"
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Call a named LLM configuration with declared tools and emit a structured tool result."
  },
  "defaults": {
    "agent_type": "executor",
    "runner_module": "MirrorNeuron.Runner.HostLocal",
    "type": "map"
  },
  "description": "Runs an LLM-backed tool-using agent through named LLM config and declared tools.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "node_type",
      "system_prompt_ref",
      "output_message_type"
    ],
    "required": [
      "llm_config",
      "tools",
      "role"
    ]
  },
  "kind": "executor",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "llm_tool_use",
    "structured_tool_result"
  ],
  "renders_to": "manifest.nodes[]",
  "template_category": "data",
  "template_id": "mn-agents.data_llm_tool",
  "version": "1.0.0"
}
