{
  "agent_type": "executor",
  "config": {
    "agent_beacon_required": true,
    "beacon_enabled": true,
    "beacon_interval_ms": 15000,
    "beacon_missed_action": "fail_attempt",
    "beacon_timeout_ms": 45000,
    "command": [
      "python3",
      "scripts/run_blueprint.py"
    ],
    "from": "base",
    "idempotent": true,
    "no_auto_providers": true,
    "no_keep": true,
    "output_message_type": "stage_documents_completed",
    "pool": "default",
    "pool_slots": 1,
    "runner_module": "MirrorNeuron.Runner.HostLocal",
    "safe_to_retry": true,
    "side_effect": "read",
    "tty": false,
    "upload_as": "document_workflow",
    "upload_path": "document_workflow",
    "workdir": "/sandbox/job/document_workflow"
  },
  "node_id": "stage_documents",
  "role": "document_stage",
  "type": "generic",
  "version": 1
}
