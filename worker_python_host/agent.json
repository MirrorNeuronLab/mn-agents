{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.worker.python_host.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "fallback_message_type": "worker_completed",
          "message_type": "config.output_message_type"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "command",
      "runner_module",
      "upload_path",
      "workdir"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "agent_completed",
            "type": "terminate"
          },
          "when": {
            "type": "always"
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Run a Python script on the host with standard lifecycle, retry, and beacon config."
  },
  "defaults": {
    "agent_beacon_required": true,
    "agent_type": "executor",
    "beacon_enabled": true,
    "beacon_interval_ms": 15000,
    "beacon_missed_action": "fail_attempt",
    "beacon_timeout_ms": 45000,
    "from": "base",
    "no_auto_providers": true,
    "no_keep": true,
    "pool": "default",
    "pool_slots": 1,
    "runner_module": "MirrorNeuron.Runner.HostLocal",
    "tty": false,
    "type": "generic",
    "workdir_template": "/sandbox/job/{upload_path}"
  },
  "description": "Generic Python worker executed by MirrorNeuron.Runner.HostLocal.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "stereotype",
      "node_type",
      "role",
      "output_message_type",
      "environment",
      "pass_env",
      "pool",
      "pool_slots",
      "workdir",
      "command",
      "side_effect",
      "timeout_seconds",
      "max_attempts",
      "retry_backoff_ms",
      "safe_to_retry",
      "idempotent"
    ],
    "required": [
      "script",
      "upload_path"
    ]
  },
  "kind": "executor",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "runtime_shape",
    "rendered_manifest_node",
    "behavior_simulation"
  ],
  "renders_to": "manifest.nodes[]",
  "stereotypes": {
    "document_workflow_host_worker": {
      "description": "Standard host-local document workflow worker.",
      "with": {
        "command": [
          "python3",
          "scripts/run_blueprint.py"
        ],
        "idempotent": true,
        "safe_to_retry": true,
        "script": "scripts/run_blueprint.py",
        "side_effect": "read",
        "upload_as": "document_workflow",
        "upload_path": "document_workflow",
        "workdir": "/sandbox/job/document_workflow"
      }
    },
    "internal_write_worker": {
      "description": "Host-local worker that writes only internal run artifacts.",
      "with": {
        "side_effect": "internal_write"
      }
    }
  },
  "template_category": "data",
  "template_id": "mn-agents.worker.python_host",
  "version": 1
}
