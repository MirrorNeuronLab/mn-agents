{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.control_lifecycle.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "fallback_message_type": "lifecycle_control",
          "message_type": "with.output_message_type"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "action"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "lifecycle_signal_emitted",
            "type": "terminate"
          },
          "when": {
            "type": "always"
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Emit a lifecycle control signal that starts, stops, pauses, or resumes workflow progress."
  },
  "defaults": {
    "agent_type": "router",
    "type": "map"
  },
  "description": "Emits workflow lifecycle control messages such as start, stop, pause, and resume.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "node_type",
      "role",
      "reason",
      "output_message_type"
    ],
    "required": [
      "action"
    ]
  },
  "kind": "router",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "workflow_lifecycle_control",
    "start_stop_signals"
  ],
  "renders_to": "manifest.nodes[]",
  "template_category": "control",
  "template_id": "mn-agents.control_lifecycle",
  "version": "1.0.0"
}
