{
  "defaults": {
    "agent_type": "router",
    "type": "map"
  },
  "description": "Emits an initial or routed message into a graph with optional state/backpressure config.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "emit_type",
      "node_type",
      "role",
      "backpressure",
      "conditions",
      "routing_mode"
    ],
    "required": []
  },
  "kind": "router",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "message_routing",
    "state_driven_routing"
  ],
  "renders_to": "manifest.nodes[]",
  "template_id": "mn-agents.router_agent",
  "version": "1.0.0"
}
