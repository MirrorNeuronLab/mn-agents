{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.data_sandboxed_codegen.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "fallback_message_type": "codegen_result",
          "message_type": "with.output_message_type"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "llm_config",
      "task",
      "sandbox",
      "runner_module"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "sandboxed_codegen_completed",
            "type": "terminate"
          },
          "when": {
            "type": "always"
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Use an LLM for code work while preserving an explicit sandbox execution boundary."
  },
  "defaults": {
    "agent_type": "executor",
    "runner_module": "MirrorNeuron.Sandbox.OpenShell",
    "type": "map"
  },
  "description": "Runs code-generation or code-review work inside an explicit sandbox boundary.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "node_type",
      "role",
      "policy",
      "output_message_type"
    ],
    "required": [
      "llm_config",
      "task",
      "sandbox"
    ]
  },
  "kind": "executor",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "sandboxed_codegen",
    "code_review",
    "isolated_execution"
  ],
  "renders_to": "manifest.nodes[]",
  "template_category": "data",
  "template_id": "mn-agents.data_sandboxed_codegen",
  "version": "1.0.0"
}
