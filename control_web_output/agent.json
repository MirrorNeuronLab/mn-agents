{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.control_web_output.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "message_type": "web_ui_available"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "adapter",
      "fallback_port",
      "primary_port",
      "runner_module"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "web_ui_available",
            "type": "terminate"
          },
          "when": {
            "type": "always"
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Expose web UI output endpoints with primary and fallback port conventions."
  },
  "defaults": {
    "agent_type": "executor",
    "fallback_port": 8081,
    "primary_port": 8080,
    "runner_module": "MirrorNeuron.Runner.OpenShell",
    "type": "generic"
  },
  "description": "TCP output and web UI service using primary port 8080 and fallback port 8081.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "node_type",
      "role",
      "primary_port",
      "fallback_port",
      "custom_url"
    ],
    "required": [
      "adapter"
    ]
  },
  "kind": "service",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "web_ui",
    "tcp_output",
    "port_tunnel_verification"
  ],
  "renders_to": "manifest.nodes[]",
  "template_category": "control",
  "template_id": "mn-agents.control_web_output",
  "version": 1
}
