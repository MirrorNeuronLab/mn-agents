{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.data_module.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "message_type": "native_runtime_message"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "module"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "module_message_emitted",
            "type": "terminate"
          },
          "when": {
            "type": "always"
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Run a native MirrorNeuron module node and emit its runtime message."
  },
  "defaults": {
    "agent_type": "module",
    "type": "generic"
  },
  "description": "Runs a native MirrorNeuron or BEAM module node with standard manifest wiring.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "node_type",
      "role",
      "module_source",
      "emit_type",
      "answer_node",
      "backpressure"
    ],
    "required": [
      "module"
    ]
  },
  "kind": "module",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "native_runtime_module",
    "structured_runtime_config"
  ],
  "renders_to": "manifest.nodes[]",
  "template_category": "data",
  "template_id": "mn-agents.data_module",
  "version": "1.0.0"
}
