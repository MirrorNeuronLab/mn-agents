{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.data_llm_decision.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "fallback_message_type": "llm_decision",
          "message_type": "with.output_message_type"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "llm_config",
      "runner_module"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "llm_decision_emitted",
            "type": "terminate"
          },
          "when": {
            "tool_name": "handoff",
            "type": "tool_called"
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Call a named LLM configuration and emit a structured decision message."
  },
  "defaults": {
    "agent_type": "executor",
    "runner_module": "MirrorNeuron.Runner.HostLocal",
    "type": "map"
  },
  "description": "Named LLM_CONFIG based LLM agent with optional A2A discovery metadata.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "node_type",
      "system_prompt_ref",
      "tools",
      "output_message_type"
    ],
    "required": [
      "llm_config",
      "role"
    ]
  },
  "kind": "executor",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "protocol_adapters": {
    "a2a": {
      "agent_card": "a2a/agent-card.json",
      "enabled": true,
      "input_envelope": "Message",
      "output_envelope": "Artifact",
      "recommended_for": [
        "python_llm_agent"
      ]
    }
  },
  "provides": [
    "llm_call",
    "a2a_optional",
    "structured_decision"
  ],
  "renders_to": "manifest.nodes[]",
  "template_category": "data",
  "template_id": "mn-agents.data_llm_decision",
  "version": "1.0.0"
}
