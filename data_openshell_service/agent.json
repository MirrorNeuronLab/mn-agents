{
  "behavior": {
    "delegation": {
      "allow_recursive": false,
      "enabled": false,
      "inherits_tools": false
    },
    "emits": {
      "artifacts": [
        {
          "artifact_id": "result",
          "mime_type": "application/json",
          "schema": "mn-agents.data_openshell_service.output.v1"
        }
      ],
      "events": [
        "agent_started",
        "agent_completed",
        "agent_failed"
      ],
      "messages": [
        {
          "message_type": "service_ready"
        },
        {
          "message_type": "service_failed"
        }
      ]
    },
    "lifecycle_events": {
      "failure": [
        "agent_started",
        "agent_failed"
      ],
      "success": [
        "agent_started",
        "agent_completed"
      ]
    },
    "required_config": [
      "custom_openshell_image",
      "container_port",
      "external_port",
      "runner_module",
      "tunnel"
    ],
    "routing": {
      "transitions": [
        {
          "then": {
            "reason": "service_status_reported",
            "type": "terminate"
          },
          "when": {
            "type": "always"
          }
        }
      ]
    },
    "schema_version": "mn.agent.behavior.v1",
    "summary": "Start an OpenShell-backed service and report service readiness or failure."
  },
  "defaults": {
    "agent_type": "executor",
    "required": true,
    "runner_module": "MirrorNeuron.Runner.OpenShell",
    "type": "generic"
  },
  "description": "Custom OpenShell service with explicit port and SSH tunnel verification.",
  "input_spec": "input.spec.json",
  "inputs": {
    "optional": [
      "node_type",
      "role",
      "required",
      "healthcheck_path"
    ],
    "required": [
      "custom_openshell_image",
      "container_port",
      "external_port",
      "tunnel"
    ]
  },
  "kind": "service",
  "output_spec": "output.spec.json",
  "payloads": "payloads",
  "provides": [
    "openshell_service",
    "port_tunnel_verification"
  ],
  "renders_to": "manifest.nodes[]",
  "template_category": "data",
  "template_id": "mn-agents.data_openshell_service",
  "version": 1
}
